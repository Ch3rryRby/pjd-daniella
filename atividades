using System;

class Program
{
    static void Main()
    {
        // Inicializando o numero aleatorio entre 1 e 100
        Random random = new Random();
        int numeroSecreto = random.Next(1, 101);

        int tentativasRestantes = 10;  // Limite de tentativas
        bool acertou = false;

        Console.WriteLine("Bem-vindo ao jogo de adivinhacao!");
        Console.WriteLine("Tente adivinhar o numero entre 1 e 100.");
        Console.WriteLine("Voce tem 10 tentativas.");

        while (tentativasRestantes > 0 && !acertou)
        {
            Console.WriteLine($"\nVoce tem {tentativasRestantes} tentativas restantes.");
            Console.Write("Digite o seu palpite: ");
            string entrada = Console.ReadLine();

            // Verificando se a entrada é um número válido
            if (int.TryParse(entrada, out int palpite))
            {
                // Verificando se o palpite está correto
                if (palpite == numeroSecreto)
                {
                    Console.WriteLine("Parabens! Você acertou o numero!");
                    acertou = true;
                }
                else if (palpite < numeroSecreto)
                {
                    Console.WriteLine("O numero secreto é maior. Tente novamente.");
                }
                else
                {
                    Console.WriteLine("O numero secreto é menor. Tente novamente.");
                }
            }
            else
            {
                Console.WriteLine("Por favor, insira um numero valido.");
            }

            // Decrementa o número de tentativas
            tentativasRestantes--;
        }

        // Se não acertou dentro do número de tentativas
        if (!acertou)
        {
            Console.WriteLine($"\nGAME OVER. Suas tentativas acabaram. O numero secreto era {numeroSecreto}.");
        }

        Console.WriteLine("Obrigado por jogar!");
    }
}
